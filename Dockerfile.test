# Test runner image - built locally, not pushed to registry
# Usage: docker build -t jenkins-agent-test:local -f Dockerfile.test .

FROM python:3.12-slim

# Install test dependencies (cached in image layer)
RUN pip install --no-cache-dir \
    pytest>=7.4.0 \
    pyyaml>=6.0 \
    beautifulsoup4>=4.12.0

WORKDIR /app

# Default command runs all tests
CMD ["pytest", "tests/", "-v"]

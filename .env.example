# Jenkins Failure Analysis Agent v1.6 - Environment Variables
# Copy this file to .env and fill in your values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker-compose up -d
#
# Choose your deployment mode:
#   1. Full local (Ollama in Docker):     docker-compose up -d
#   2. External Ollama (on host):         docker-compose -f docker-compose.external-ollama.yml up -d
#   3. Remote AI API (OpenAI, etc.):      docker-compose -f docker-compose.remote-ai.yml up -d
#
# Pre-built image deployment (no build required):
#   4. Pre-built + Ollama in Docker:      docker-compose -f docker-compose.prebuilt.yml up -d
#   5. Pre-built + External Ollama:       docker-compose -f docker-compose.prebuilt-external.yml up -d
#
# Analysis Modes:
#   - Standard (scripted):  Single LLM call, ~2 seconds
#   - Iterative:            Multi-call analysis with source context (recommended)
#   - Deep (agentic):       Multi-step MCP investigation, ~30+ seconds

# =============================================================================
# PRE-BUILT IMAGE CONFIGURATION (Optional)
# =============================================================================
# Only needed if using docker-compose.prebuilt*.yml files
# Leave commented to use the default image from GitHub Container Registry

# AGENT_IMAGE=ghcr.io/your-org/jenkins-failure-agent:latest
# AGENT_IMAGE=ghcr.io/your-org/jenkins-failure-agent:v1.4.0

# =============================================================================
# JENKINS CONFIGURATION (Required)
# =============================================================================

# Your Jenkins server URL
# For Jenkins running on host machine: http://host.docker.internal:8080
# For Jenkins in Docker network: http://jenkins:8080
# For remote Jenkins: https://jenkins.yourcompany.com
JENKINS_URL=http://host.docker.internal:8080

# Jenkins credentials (create an API token in Jenkins user settings)
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=your-api-token-here

# SSL verification - see "SSL VERIFICATION" section below for global setting
# Override for Jenkins only: JENKINS_VERIFY_SSL=false

# =============================================================================
# AI CONFIGURATION - Choose ONE of the following options
# =============================================================================

# AI timeout (increase for deep investigation or slow models)
AI_TIMEOUT=120

# -----------------------------------------------------------------------------
# OPTION 1: Ollama in Docker (default docker-compose.yml)
# -----------------------------------------------------------------------------
# No configuration needed - defaults work out of the box
# The docker-compose.yml includes Ollama and pulls llama3:8b automatically
#
# AI_BASE_URL=http://ollama:11434/v1
# AI_MODEL=llama3:8b
# AI_API_KEY=ollama

# -----------------------------------------------------------------------------
# OPTION 2: External Ollama (docker-compose.external-ollama.yml)
# -----------------------------------------------------------------------------
# Use when Ollama is installed on your host machine
# Better GPU performance (native CUDA/Metal acceleration)
#
# Prerequisites:
#   1. Install Ollama: https://ollama.ai/download
#   2. Start Ollama: ollama serve  (or it runs as a service)
#   3. Pull model: ollama pull llama3:8b
#
# Uncomment these for external Ollama:
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_MODEL=llama3:8b
# AI_API_KEY=ollama
#
# For deep investigation (recommended for agentic mode):
# AI_MODEL=llama3:70b
# AI_MODEL=deepseek-coder:33b
# AI_MODEL=codellama:70b

# -----------------------------------------------------------------------------
# OPTION 3: Remote vLLM Server (docker-compose.external-ollama.yml)
# -----------------------------------------------------------------------------
# Use when you have a vLLM server running on your network
#
# AI_BASE_URL=http://your-vllm-server:8000/v1
# AI_MODEL=meta-llama/Llama-3-70b-chat-hf
# AI_API_KEY=your-vllm-api-key

# -----------------------------------------------------------------------------
# OPTION 4: OpenAI API (docker-compose.remote-ai.yml)
# -----------------------------------------------------------------------------
# Use OpenAI's models (data will leave your infrastructure)
# Recommended for deep investigation: gpt-4-turbo, gpt-4o
#
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4-turbo
# AI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# OPTION 5: Azure OpenAI (docker-compose.remote-ai.yml)
# -----------------------------------------------------------------------------
# Use Azure-hosted OpenAI models
#
# AI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# AI_MODEL=gpt-4
# AI_API_KEY=your-azure-api-key

# -----------------------------------------------------------------------------
# OPTION 6: Anthropic Claude (docker-compose.remote-ai.yml)
# -----------------------------------------------------------------------------
# Use Claude models (best for complex investigations)
#
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-3-opus-20240229
# AI_API_KEY=sk-ant-your-key

# -----------------------------------------------------------------------------
# OPTION 7: AWS Bedrock (docker-compose.bedrock.yml)
# -----------------------------------------------------------------------------
# Use AWS Bedrock with Claude, Titan, Llama, or Mistral models
# Data stays in your AWS account
#
# Prerequisites:
#   1. Enable model access in AWS Console → Bedrock → Model access
#   2. Configure AWS credentials (see below)
#   3. IAM permissions: bedrock:InvokeModel
#
# AI_PROVIDER=bedrock
# AI_MODEL=claude-3-sonnet
# AI_REGION=us-east-1
#
# AWS Authentication (choose one):
#   A. Environment variables:
#      AWS_ACCESS_KEY_ID=AKIA...
#      AWS_SECRET_ACCESS_KEY=...
#      AWS_REGION=us-east-1
#
#   B. IAM role (for EC2/ECS/EKS) - no config needed
#
#   C. AWS credentials file - mount ~/.aws in container
#      AWS_PROFILE=your-profile
#
# Model options:
#   claude-3-sonnet, claude-3-haiku, claude-3-opus, claude-3.5-sonnet
#   titan-express, titan-lite
#   llama3-8b, llama3-70b
#   mistral-7b, mistral-large, mixtral-8x7b

# =============================================================================
# GITHUB ENTERPRISE - SOURCE CODE FETCHING
# =============================================================================
# Required for deep investigation of custom Groovy shared libraries
# The agent needs access to your library source code to trace errors

# Enable GitHub integration
GITHUB_ENABLED=false

# GitHub API base URL
# GitHub.com:        https://api.github.com
# GitHub Enterprise: https://github.yourcompany.com/api/v3
GITHUB_BASE_URL=https://api.github.com

# Personal access token with repo read access
# Create at: GitHub → Settings → Developer settings → Personal access tokens
# Required scopes: repo (read access to private repositories)
GITHUB_TOKEN=ghp_your_token_here

# SSL verification - see "SSL VERIFICATION" section below for global setting
# Override for GitHub only: GITHUB_VERIFY_SSL=false

# Note: Library mappings must be configured in config.yaml
# They map @Library('name') declarations to repository paths:
#
# github:
#   library_mappings:
#     "my-pipeline-lib": "org/jenkins-shared-library"
#     "common-steps": "platform/common-pipeline-steps"

# =============================================================================
# SCM INTEGRATION - PR/MR COMMENTS (Optional)
# =============================================================================
# Post analysis results as PR/MR comments and set commit status checks

# Enable SCM integration
SCM_ENABLED=false

# Provider: github or gitlab
SCM_PROVIDER=github

# API URL (same as GITHUB_BASE_URL for GitHub)
# GitHub.com:        https://api.github.com
# GitHub Enterprise: https://github.yourcompany.com/api/v3
# GitLab.com:        https://gitlab.com/api/v4
# GitLab self-hosted: https://gitlab.yourcompany.com/api/v4
SCM_API_URL=https://api.github.com

# Personal access token with PR/MR write access
# For GitHub, same token as GITHUB_TOKEN works if it has write access
# Required scopes:
#   GitHub: repo (full) or public_repo (public only)
#   GitLab: api
SCM_TOKEN=

# SSL verification - see "SSL VERIFICATION" section below for global setting
# Override for SCM only: SCM_VERIFY_SSL=false

# Auto-comment on PRs when analysis is triggered with PR info
SCM_AUTO_COMMENT=true

# Set commit status checks (shows in PR checks)
SCM_SET_COMMIT_STATUS=true

# =============================================================================
# REPORTER OPTIONS (Optional)
# =============================================================================

# Update Jenkins build description with analysis summary
UPDATE_JENKINS_DESCRIPTION=true

# Post analysis to PR/MR (requires SCM_ENABLED=true)
POST_TO_PR=true

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================

# Slack webhook for failure notifications
SLACK_WEBHOOK_URL=

# =============================================================================
# SECURITY (Optional)
# =============================================================================

# API key to protect the agent's HTTP endpoints
# WARNING: If set, the Web UI will NOT work (it doesn't send auth headers)
# Only set this if using API-only mode (no UI) or behind a proxy with auth
# Leave empty to allow UI access
SERVER_API_KEY=

# =============================================================================
# SSL VERIFICATION (Optional)
# =============================================================================

# Global SSL certificate verification for all outgoing requests
# Set to "false" when using self-signed certificates or internal CAs
# WARNING: Only disable in trusted environments
# VERIFY_SSL=false

# Per-service overrides (if not set, uses VERIFY_SSL value)
# JENKINS_VERIFY_SSL=false
# GITHUB_VERIFY_SSL=false
# SCM_VERIFY_SSL=false

# =============================================================================
# LOG PARSING (Optional)
# =============================================================================

# Shared library method execution prefix for tracking which method is running
# This helps identify which library function was executing when failure occurred
# Pattern in logs: "{prefix}: method_name"
# Example: "deploy-service-execution: deployToKubernetes"
# Leave empty if not using method tracking in your shared library
METHOD_EXECUTION_PREFIX=
# =============================================================================
# ITERATIVE ROOT CAUSE ANALYZER (Optional)
# =============================================================================
# Multi-call AI analysis that iteratively narrows down root cause

# Enable iterative RC analyzer (recommended)
RC_ANALYZER_ENABLED=true

# Maximum AI calls per analysis request
RC_ANALYZER_MAX_ITERATIONS=3

# Confidence threshold (0.0-1.0) - stop iterating when reached
RC_ANALYZER_CONFIDENCE_THRESHOLD=0.7

# Maximum source code characters to include in prompts
RC_ANALYZER_MAX_SOURCE_CHARS=8000

# =============================================================================
# JENKINSFILE SOURCE (Optional)
# =============================================================================
# Configure where to find the Jenkinsfile for source context

# GitHub repository containing Jenkinsfile (owner/repo format)
# Leave empty for auto-detection from build SCM info
JENKINSFILE_REPO=

# Git ref (branch/tag) for Jenkinsfile
JENKINSFILE_REF=main

# =============================================================================
# SPLUNK INTEGRATION (Optional)
# =============================================================================
# Pull failed build logs from Splunk for automated analysis

# Enable Splunk integration
SPLUNK_ENABLED=false

# Splunk API URL (typically port 8089 for REST API)
SPLUNK_URL=https://splunk.company.com:8089

# Splunk Bearer token for authentication
# Create at: Settings → Tokens → New Token
SPLUNK_TOKEN=your-splunk-token

# Splunk index containing Jenkins console logs
SPLUNK_INDEX=jenkins_console

# Search filter to limit which pipelines to analyze
# Example: "abc/shared-code" or "team-name/*"
SPLUNK_SEARCH_FILTER=

# Number of log lines to fetch from end (errors usually at end)
SPLUNK_LOG_TAIL_LINES=500

# Sync interval in minutes (how often to pull failed builds)
SPLUNK_SYNC_INTERVAL_MINS=15

# Max seconds to wait for Splunk search job completion
SPLUNK_TIMEOUT=180

# Max sources returned by filter subsearch fallback
SPLUNK_SOURCE_SUBSEARCH_LIMIT=1000

# SSL verification for Splunk API
SPLUNK_VERIFY_SSL=false
